{
  "version": 2,
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/app/main.py"
    }
  ],
  "regions": [
    "iad1"
  ],
  "functions": {
    "app/main.py": {
      "memory": 1024,
      "maxDuration": 10
    }
  }
}