# Secret key for JWT token signing and session security
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-secret-key

# Database URL for SQLAlchemy async engine
# For SQLite (development): sqlite+aiosqlite:///./talentflow.db
# For PostgreSQL (production): postgresql+asyncpg://user:password@localhost:5432/talentflow
DATABASE_URL=sqlite+aiosqlite:///./talentflow.db

# Default admin account created on first startup
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changeme123

# Session max age in seconds (default: 86400 = 24 hours)
SESSION_MAX_AGE=86400

# Debug mode (set to False in production)
DEBUG=True